{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start backend (web-app)",
      "type": "shell",
      "command": "set -a && source \"${workspaceFolder}/local.env\" && set +a && exec sbt \"project web-app\" run",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
